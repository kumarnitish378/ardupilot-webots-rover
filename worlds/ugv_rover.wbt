  name "rock_ahead"
}
Rock {
  translation 1.2 -0.9 0
  rotation 0 0 1 0.8
  name "rock_side"
  scale 1.3
}
Rock {
  translation -1.3 1.0 0
  rotation 0 0 1 2.1
  name "rock_small"
  scale 0.7
}
