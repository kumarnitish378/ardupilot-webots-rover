EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/rocks/protos/Rock.proto"

WorldInfo {
  title "ugv_rover"
  # Halved from 16ms: the chassis -> suspension -> lightweight steering-knuckle
  # -> wheel joint chain is numerically stiff once real rolling/contact forces
  # are involved (a light knuckle sandwiched between much heavier bodies), and
  # 16ms let the solver occasionally lose the steering joint's stop constraint
  # for a single step before self-correcting. More sub-steps fixes that.
  basicTimeStep 8
  contactProperties [
    ContactProperties {
      material1 "wheel"
      material2 "floor"
      # Single isotropic value: with front-wheel steering + a driven rear axle,
      # turning comes from the steering angle, not lateral wheel scrub, so the
      # anisotropic (skid-steer) friction split is no longer needed.
      coulombFriction [2.5]
      bounce 0.0
      softCFM 0.0001
    }
    ContactProperties {
      # Rocks use the "default" contactMaterial. Their mesh is an irregular
      # bumpy surface, so a wheel resting against one can generate more than
      # the engine's default cap of 10 contact points (we saw 11) - raising
      # maxContactJoints here stops it from silently dropping the deepest ones.
      material1 "wheel"
      material2 "default"
      maxContactJoints 20
    }
  ]
}
# Coordinate system: ENU (default for new R2025a worlds) -> X = forward, Y = left, Z = up.
# Camera / DistanceSensor default "forward" axis is +X, so no extra rotation is needed
# to make them look ahead of the chassis.
Viewpoint {
  orientation -0.262 0.0796 0.9616 2.575
  position 3.0 -3.0 2.2
}
TexturedBackground {
}
TexturedBackgroundLight {
}
RectangleArena {
  floorSize 10 10
  floorTileSize 1 1
  wallHeight 0.1
  contactMaterial "floor"
}
# Small static obstacles (no physics needed - Rock's default physics is NULL,
# so it behaves as a fixed obstacle) for distance-sensor and rough-driving tests.
Rock {
